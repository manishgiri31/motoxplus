generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String           @id @default(cuid())
  name                String?
  email               String           @unique
  emailVerified       DateTime?
  emailVerifiedAt     DateTime?
  image               String?
  password            String?
  role                UserRole         @default(DEALER)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  department          StaffDepartment?
  mobileNumber        String?          @unique
  mobileVerified      Boolean          @default(false)
  mobileVerifiedAt    DateTime?
  lastLogin           DateTime?
  failedLoginAttempts Int              @default(0)
  accountLockedUntil  DateTime?
  twoFactorEnabled    Boolean          @default(false)
  isActive            Boolean          @default(true)
  accounts            Account[]
  admin               Admin?
  dealer              Dealer?
  sessions            Session[]
  userSessions        UserSession[]
  otpCodes            OtpCode[]
  vendor              Vendor?
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  type      OtpType
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dealer {
  id                 String               @id @default(cuid())
  userId             String               @unique
  companyName        String
  gstNumber          String               @unique
  ownerName          String
  phone              String
  state              String
  city               String
  address            String
  pincode            String
  status             DealerStatus         @default(PENDING)
  creditLimit        Float                @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  cart               Cart?
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents          DealerDocument[]
  invoices           Invoice[]
  orders             Order[]
  paymentSubmissions PaymentSubmission[]
}

model Admin {
  id           String   @id @default(cuid())
  userId       String   @unique
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id              String         @id @default(cuid())
  name            String
  sku             String         @unique
  partNumber      String         @unique
  description     String?
  categoryId      String
  weight          Float?
  moq             Int            @default(1)
  price           Float
  mrp             Float?
  gstRate         Float          @default(18)
  images          String[]
  compatibility   String[]
  isActive        Boolean        @default(true)
  stock           Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  brand           String         @default("MOTOXPLUS")
  countryOfOrigin String         @default("India")
  hsnCode         String         @default("")
  oemNumber       String?
  packageHeight   Float?
  packageLength   Float?
  packageWeight   Float?
  packageWidth    Float?
  warranty        String         @default("No Warranty")
  vendorId        String?
  vendorCostPrice Float?
  markupPercent   Float?
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category       @relation(fields: [categoryId], references: [id])
  productImages   ProductImage[]
  vendor          Vendor?        @relation(fields: [vendorId], references: [id])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  imageUrl     String
  key          String   @default("")
  isPrimary    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  fileName     String   @default("")
  fileSize     Int      @default(0)
  mediumUrl    String?
  mimeType     String   @default("image/webp")
  thumbnailUrl String?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model DealerDocument {
  id           String             @id @default(cuid())
  dealerId     String
  documentType DealerDocumentType
  fileUrl      String
  fileName     String
  fileSize     Int
  mimeType     String
  key          String
  uploadedAt   DateTime           @default(now())
  dealer       Dealer             @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([dealerId, documentType])
}

model StorageAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  fileKey   String
  fileUrl   String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Cart {
  id        String     @id @default(cuid())
  dealerId  String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  dealer    Dealer     @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                  String               @id @default(cuid())
  orderNumber         String               @unique
  dealerId            String
  subtotal            Float
  gstAmount           Float
  shippingCost        Float                @default(0)
  grandTotal          Float
  paymentType         PaymentType
  amountPaid          Float                @default(0)
  amountDue           Float
  status              OrderStatus          @default(PENDING)
  paymentStatus       PaymentStatus        @default(PENDING)
  notes               String?
  shippingAddress     String?
  deliveryName        String?
  deliveryPhone       String?
  deliveryCity        String?
  deliveryState       String?
  deliveryPincode     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  invoice             Invoice?
  shipment            Shipment?
  dealer              Dealer               @relation(fields: [dealerId], references: [id])
  items               OrderItem[]
  payments            Payment[]
  paymentSubmissions  PaymentSubmission[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  gstRate   Float
  gstAmount Float
  total     Float
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  paymentType       PaymentType
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  orderId       String    @unique
  dealerId      String
  pdfUrl        String?
  subtotal      Float
  gstAmount     Float
  grandTotal    Float
  issuedAt      DateTime  @default(now())
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  dealer        Dealer    @relation(fields: [dealerId], references: [id])
  order         Order     @relation(fields: [orderId], references: [id])
}

model Vendor {
  id             String           @id @default(cuid())
  userId         String?          @unique
  vendorCode     String           @unique
  companyName    String
  ownerName      String
  email          String           @unique
  phone          String
  gstNumber      String?          @unique
  panNumber      String?
  category       VendorCategory
  status         VendorStatus     @default(PENDING)
  creditDays     Int              @default(30)
  bankName       String?
  accountNumber  String?
  ifscCode       String?
  address        String
  city           String
  state          String
  pincode        String
  website        String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  purchaseOrders PurchaseOrder[]
  user           User?            @relation(fields: [userId], references: [id])
  contacts       VendorContact[]
  documents      VendorDocument[]
  payments       VendorPayment[]
  ratings        VendorRating[]
  products       Product[]
}

model VendorContact {
  id          String   @id @default(cuid())
  vendorId    String
  name        String
  designation String?
  email       String?
  phone       String
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model VendorDocument {
  id           String             @id @default(cuid())
  vendorId     String
  documentType VendorDocumentType
  fileUrl      String
  fileName     String
  fileSize     Int                @default(0)
  key          String             @default("")
  uploadedAt   DateTime           @default(now())
  vendor       Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model VendorRating {
  id            String   @id @default(cuid())
  vendorId      String
  ratedById     String
  qualityScore  Float
  deliveryScore Float
  priceScore    Float
  overallScore  Float
  period        String
  notes         String?
  createdAt     DateTime @default(now())
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, period])
}

model VendorPayment {
  id              String         @id @default(cuid())
  vendorId        String
  amount          Float
  currency        String         @default("INR")
  paymentDate     DateTime
  paymentMode     String
  referenceNumber String?
  status          PaymentStatus  @default(PENDING)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
}

model PurchaseRequest {
  id              String                @id @default(cuid())
  requestNumber   String                @unique
  requestedById   String
  requestedByName String
  departmentCode  String                @default("GENERAL")
  title           String
  urgency         Urgency               @default(NORMAL)
  status          PurchaseRequestStatus @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  purchaseOrder   PurchaseOrder?
  items           PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id                 String          @id @default(cuid())
  purchaseRequestId  String
  description        String
  quantity           Int
  unit               String          @default("PCS")
  estimatedUnitPrice Float?
  notes              String?
  purchaseRequest    PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id                 String              @id @default(cuid())
  poNumber           String              @unique
  purchaseRequestId  String?             @unique
  vendorId           String
  createdById        String
  status             PurchaseOrderStatus @default(DRAFT)
  urgency            Urgency             @default(NORMAL)
  deliveryDate       DateTime
  deliveryAddress    String
  subtotal           Float
  taxAmount          Float               @default(0)
  grandTotal         Float
  termsAndConditions String?
  vendorNotes        String?
  rejectedAt         DateTime?
  acceptedAt         DateTime?
  closedAt           DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  goodsReceivedNotes GoodsReceivedNote[]
  purchaseRequest    PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id])
  vendor             Vendor              @relation(fields: [vendorId], references: [id])
  items              PurchaseOrderItem[]
  vendorPayments     VendorPayment[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  description     String
  quantity        Int
  receivedQty     Int           @default(0)
  unit            String        @default("PCS")
  unitPrice       Float
  gstRate         Float         @default(18)
  gstAmount       Float
  total           Float
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model GoodsReceivedNote {
  id              String              @id @default(cuid())
  grnNumber       String              @unique
  purchaseOrderId String
  receivedById    String
  receivedByName  String
  receivedAt      DateTime
  qualityStatus   String              @default("ACCEPTED")
  notes           String?
  createdAt       DateTime            @default(now())
  items           GoodsReceivedItem[]
  purchaseOrder   PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id])
}

model GoodsReceivedItem {
  id                  String            @id @default(cuid())
  goodsReceivedNoteId String
  description         String
  orderedQuantity     Int
  receivedQuantity    Int
  acceptedQuantity    Int
  rejectedQuantity    Int               @default(0)
  rejectionReason     String?
  goodsReceivedNote   GoodsReceivedNote @relation(fields: [goodsReceivedNoteId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String         @id @default(cuid())
  leadNumber     String         @unique
  companyName    String
  ownerName      String
  email          String
  phone          String
  city           String
  state          String
  status         LeadStatus     @default(NEW)
  source         LeadSource     @default(WEBSITE)
  priority       LeadPriority   @default(MEDIUM)
  assignedToId   String?
  assignedToName String?
  convertedAt    DateTime?
  dealerId       String?        @unique
  lostReason     String?
  estimatedValue Float?
  nextFollowUp   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  address        String?
  alternatePhone String?
  designation    String?
  pincode        String?
  activities     LeadActivity[]
  notes          LeadNote[]
}

model LeadActivity {
  id              String   @id @default(cuid())
  leadId          String
  performedBy     String
  performedByName String
  type            String
  description     String
  outcome         String?
  nextAction      String?
  createdAt       DateTime @default(now())
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadNote {
  id         String   @id @default(cuid())
  leadId     String
  authorId   String
  authorName String
  content    String
  isPrivate  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

enum UserRole {
  GUEST
  DEALER
  ADMIN
  SUPER_ADMIN
  VENDOR
  STAFF
  SALES
  SUPPORT
  PRODUCTION
  DISPATCH
  ACCOUNTS
  MARKETING
}

enum OtpType {
  EMAIL_VERIFICATION
  MOBILE_VERIFICATION
  LOGIN
  FORGOT_PASSWORD
}

enum StaffDepartment {
  SALES
  MARKETING
  PRODUCTION
  ACCOUNTS
}

enum DealerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum PaymentType {
  ADVANCE_20
  FULL_100
  COD
}

enum DealerDocumentType {
  GST_CERTIFICATE
  PAN_CARD
  BUSINESS_REGISTRATION
  SHOP_IMAGE
  OTHER
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  BLACKLISTED
}

enum VendorCategory {
  RAW_MATERIALS
  PACKAGING
  PRINTING
  LOGISTICS
  MANUFACTURING_COMPONENTS
  TOOLING
  SERVICES
}

enum VendorDocumentType {
  GST_CERTIFICATE
  PAN_CARD
  BUSINESS_REGISTRATION
  BANK_STATEMENT
  CANCELLED_CHEQUE
  OTHER
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum Urgency {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NEGOTIATION
  CONVERTED
  LOST
  DORMANT
}

enum LeadSource {
  WEBSITE
  REFERRAL
  TRADE_SHOW
  COLD_CALL
  SOCIAL_MEDIA
  WHATSAPP
  WALK_IN
  OTHER
  ADVERTISEMENT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model Shipment {
  id               String                  @id @default(cuid())
  orderId          String                  @unique
  waybill          String                  @unique
  status           ShipmentStatus          @default(PENDING)
  trackingUrl      String?
  expectedDelivery DateTime?
  weight           Float?
  pickupDate       DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  order            Order                   @relation(fields: [orderId], references: [id])
  events           ShipmentTrackingEvent[]
}

model ShipmentTrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String
  status     String
  location   String?
  activity   String?
  timestamp  DateTime
  createdAt  DateTime @default(now())
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model ShippingRate {
  id         String   @id @default(cuid())
  zoneName   String
  states     String[]
  minWeight  Float
  maxWeight  Float
  baseRate   Float
  perKgRate  Float
  baseWeight Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String
  pincode   String
  city      String
  state     String
  phone     String
  gstin     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ShipmentStatus {
  PENDING
  MANIFESTED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  RETURNED
  CANCELLED
}

enum UpiSubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum DirectPaymentMethod {
  UPI
  BANK_TRANSFER
}

model PaymentSubmission {
  id              String              @id @default(cuid())
  orderId         String
  dealerId        String
  paymentMethod   DirectPaymentMethod
  utrNumber       String
  payerName       String
  payerEmail      String
  payerPhone      String
  screenshotUrl   String
  screenshotKey   String
  amount          Float
  status          UpiSubmissionStatus @default(SUBMITTED)
  notes           String?
  rejectionReason String?
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  ipAddress       String?
  submittedAt     DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  order           Order               @relation(fields: [orderId], references: [id])
  dealer          Dealer              @relation(fields: [dealerId], references: [id])

  @@unique([utrNumber])
}
