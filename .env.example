# =============================================================================
# MOTOXPLUS — ENVIRONMENT VARIABLES REFERENCE
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# All variables marked [REQUIRED] will crash the app on startup if missing.
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================

# [REQUIRED] PostgreSQL connection string
# Production: use local socket for best performance
# Example (TCP): postgresql://user:password@localhost:5432/motoxplus
# Example (socket): postgresql://user:password@localhost/motoxplus?host=/var/run/postgresql
DATABASE_URL="postgresql://motoxplus:STRONG_PASSWORD_HERE@localhost:5432/motoxplus"

# =============================================================================
# NEXTAUTH
# =============================================================================

# [REQUIRED] Public URL of your application (no trailing slash)
NEXTAUTH_URL="https://motoxplus.com"

# [REQUIRED] Random 64-char secret — generate with: openssl rand -hex 32
NEXTAUTH_SECRET="replace_with_64_char_random_hex_string"

# =============================================================================
# RAZORPAY PAYMENTS
# =============================================================================

# [REQUIRED] Get from https://dashboard.razorpay.com/app/keys
# Use rzp_live_* for production, rzp_test_* for development
RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXX"

# [REQUIRED] Same key exposed to browser (only key_id, never key_secret)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXXX"

# =============================================================================
# CLOUDFLARE R2 STORAGE
# =============================================================================

# [REQUIRED] Found in Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="motoxplus-assets"

# [REQUIRED] Public R2 bucket URL (enable public access on R2 bucket first)
R2_PUBLIC_URL="https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev"

# =============================================================================
# DELHIVERY SHIPPING
# =============================================================================

# [OPTIONAL] Delhivery API token — get from Delhivery partner portal
DELHIVERY_API_TOKEN="your_delhivery_api_token"
DELHIVERY_BASE_URL="https://track.delhivery.com"
DELHIVERY_ORIGIN_PINCODE="110046"

# [OPTIONAL] Random secret for webhook signature verification
# Generate: openssl rand -hex 32
DELHIVERY_WEBHOOK_SECRET="your_delhivery_webhook_secret"

DELHIVERY_PICKUP_NAME="MotoXPlus India Pvt. Ltd."
DELHIVERY_PICKUP_ADDRESS="Your pickup address"
DELHIVERY_PICKUP_CITY="New Delhi"
DELHIVERY_PICKUP_STATE="Delhi"
DELHIVERY_PICKUP_PHONE="9999999999"

# =============================================================================
# JWT (Custom auth sessions — separate from NextAuth)
# =============================================================================

# [REQUIRED] Random 64-char secret — generate with: openssl rand -hex 32
JWT_SECRET="replace_with_64_char_random_hex_string"

# =============================================================================
# EMAIL — RESEND
# =============================================================================

# [REQUIRED] Get from https://resend.com/api-keys
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# [REQUIRED] Verified sender email (must be verified in Resend dashboard)
EMAIL_FROM="noreply@motoxplus.in"

# [OPTIONAL] Inbox that receives website contact-form enquiries — falls back to NEXT_PUBLIC_COMPANY_EMAIL, then EMAIL_FROM
CONTACT_EMAIL="info@motoxplus.in"

# =============================================================================
# SMS — MSG91
# =============================================================================

# [OPTIONAL] SMS provider: "msg91" | "twilio" | "fast2sms"
SMS_PROVIDER="msg91"

# MSG91 credentials — https://msg91.com/
MSG91_AUTH_KEY="your_msg91_auth_key"
MSG91_SENDER_ID="MOTOXX"
MSG91_OTP_TEMPLATE_ID="your_msg91_otp_template_id"
MSG91_FLOW_ID="your_msg91_flow_id"

# Twilio (alternative) — https://www.twilio.com/
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_PHONE_NUMBER="+1234567890"

# =============================================================================
# REDIS (Rate limiting & session caching)
# =============================================================================

# [OPTIONAL] Redis connection URL — if not set, falls back to in-memory rate limiting
# For production with PM2 cluster mode, Redis is strongly recommended
# Install: sudo apt install redis-server
REDIS_URL="redis://localhost:6379"

# =============================================================================
# APPLICATION
# =============================================================================

# [REQUIRED] Full public URL (used in emails, og:url, canonical tags)
NEXT_PUBLIC_APP_URL="https://motoxplus.com"

# [REQUIRED] Company info (displayed throughout the app)
NEXT_PUBLIC_COMPANY_NAME="MOTOXPLUS India Private Limited"
NEXT_PUBLIC_COMPANY_WHATSAPP="91 92171 31801"
NEXT_PUBLIC_COMPANY_GST="07AAUCM5765B1Z4"
NEXT_PUBLIC_COMPANY_ADDRESS="RZ-43/291, Street Number 6, Geetanjli Park, Sagarpur West, New Delhi, South West Delhi, Delhi, 110046"
NEXT_PUBLIC_COMPANY_PHONE="+91 92171 31801"
NEXT_PUBLIC_COMPANY_EMAIL="info@motoxplus.in"
NEXT_PUBLIC_COMPANY_WEBSITE="www.motoxplus.in"
